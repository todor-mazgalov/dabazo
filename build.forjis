version: 1

repositories:
  - type: git
    url: https://github.com/todor-mazgalov/forjis-plugins.git
    ref: main
    
plugins:
  - name: software-dev

orgs:
  - name: dabazo
    teams:
      - name: Research
        extends: software-dev:RnD:Research
      - name: Dev
        extends: software-dev:RnD:Go

personas:
  dir: ./personas

tasks:
  source: dir
  path: ./tasks

constraints:
  include:
    - software-dev:git

